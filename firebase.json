{
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      "firestore.rules",
      "firestore.indexes.json",
      "firebaserc",
      "**/.*",
      "**/node_modules/**",
      "platform/config.js"
    ],
    "headers": [
      {
        "source": "**/*.@(js|css|html)",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=3600"
          }
        ]
      }
    ],
    "rewrites": [
      {
        "source": "/dashboard",
        "destination": "/platform/ui/dashboard.html"
      },
      {
        "source": "/auth",
        "destination": "/platform/auth/auth.html"
      }
    ]
  },

  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  }
}
