    .role-cards { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-top: 24px; }

    .role-card {
      border: 0.5px solid var(--border);
      border-radius: var(--r);
      padding: 20px 14px;
      cursor: pointer;
      text-align: center;
      background: var(--surface);
      transition: border-color .18s, background .18s, box-shadow .18s;
    }
    .role-card:hover { border-color: var(--accent); background: var(--accent-l); box-shadow: 0 0 0 3px var(--accent-l); }

    .role-card.green:hover { border-color: var(--green); background: var(--green-l); box-shadow: 0 0 0 3px var(--green-l); }

    .role-icon {
      width: 44px; height: 44px;
      border-radius: 12px;
      display: flex; align-items: center; justify-content: center;
      margin: 0 auto 12px;
      font-size: 22px;
    }
    .role-icon.blue { background: var(--accent-l); }
    .role-icon.green-bg { background: var(--green-l); }

    .role-card h3 { font-size: 16px; font-weight: 700; margin-bottom: 4px; }
    .role-card p  { font-size: 12px; color: var(--muted); line-height: 1.5; }

    /* ── شاشة الترحيب ── */
    .welcome-icon {
      width: 56px; height: 56px;
      border-radius: 16px;
      background: var(--accent-l);
      display: flex; align-items: center; justify-content: center;
      margin: 0 auto 20px;
      font-size: 26px;
    }
    .role-badge {
      display: inline-block;
      background: var(--accent-l);
      color: var(--accent);
      border: 0.5px solid var(--accent-b);
      border-radius: 20px;
      padding: 4px 14px;
      font-size: 13px;
      font-weight: 500;
      margin-bottom: 24px;
    }
    .btn-primary {
      width: 100%;
      padding: 13px;
      border-radius: var(--r);
      border: none;
      background: var(--accent);
      color: #fff;
      font-family: 'Tajawal', sans-serif;
      font-size: 15px;
      font-weight: 500;
      cursor: pointer;
      transition: background .18s;
      margin-bottom: 10px;
    }
    .btn-primary:hover { background: #3d5f8f; }
    .btn-link {
      background: none; border: none;
      font-family: 'Tajawal', sans-serif;
      font-size: 13px; color: var(--muted);
      cursor: pointer; text-decoration: underline;
    }
    .btn-link:hover { color: var(--text); }

    @media (max-width: 480px) {
      .card { padding: 28px 20px; }
      .role-cards { grid-template-columns: 1fr; }
    }
  </style>
</head>
<body>

  <!-- ── شاشة 1: الدخول ── -->
  <div class="screen active" id="screen-login">
    <div class="card">
      <div class="logo-wrap">
        <div class="logo-mark">
          <svg viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round">
            <circle cx="12" cy="12" r="3"/>
            <path d="M12 2v3M12 19v3M2 12h3M19 12h3"/>
            <path d="M5.6 5.6l2.1 2.1M16.3 16.3l2.1 2.1M5.6 18.4l2.1-2.1M16.3 7.7l2.1-2.1"/>
          </svg>
        </div>
        <div class="logo-name">آدميتي <small>Platform</small></div>
      </div>

      <h2>أهلاً بك</h2>
      <p class="sub">سجّل دخولك للانضمام إلى منصة آدميتي<br>ومجتمع المفيدين والمستفيدين.</p>

      <button class="btn-google" id="btn-google" onclick="signInWithGoogle()">
        <svg width="20" height="20" viewBox="0 0 24 24">
          <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
          <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
          <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z"/>
          <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
        </svg>
        الدخول عبر Google
      </button>

      <div id="error-msg"></div>

      <div class="sep"></div>
      <p style="font-size:12px;color:var(--dim)">بالدخول توافق على سياسة الاستخدام والقانون المجتمعي لآدميتي</p>
    </div>
  </div>

  <!-- ── شاشة 2: اختيار الدور ── -->
  <div class="screen" id="screen-role">
    <div class="card">
      <div class="logo-wrap">
        <div class="logo-mark">
          <svg viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round">
            <circle cx="12" cy="12" r="3"/>
            <path d="M12 2v3M12 19v3M2 12h3M19 12h3"/>
            <path d="M5.6 5.6l2.1 2.1M16.3 16.3l2.1 2.1M5.6 18.4l2.1-2.1M16.3 7.7l2.1-2.1"/>
          </svg>
        </div>
        <div class="logo-name">آدميتي <small>Platform</small></div>
      </div>

      <h2>مرحباً <span id="role-name"></span> 👋</h2>
      <p class="sub">كيف ستبدأ رحلتك في آدميتي؟<br>يمكنك تغيير دورك لاحقاً في أي وقت.</p>

      <div class="role-cards">
        <div class="role-card" onclick="selectRole('mufeed')">
          <div class="role-icon blue">🤝</div>
          <h3>مفيد</h3>
          <p>أقدّم خدماتي ومشاريعي للآخرين</p>
        </div>
        <div class="role-card green" onclick="selectRole('mustafeed')">
          <div class="role-icon green-bg">🌱</div>
          <h3>مستفيد</h3>
          <p>أبحث عن خدمات ومشاريع تناسبني</p>
        </div>
      </div>
    </div>
  </div>

  <!-- ── شاشة 3: الترحيب ── -->
  <div class="screen" id="screen-welcome">
    <div class="card">
      <div class="welcome-icon">✨</div>
      <h2>أنت الآن جزء من آدميتي</h2>
      <p class="sub" style="margin-bottom:16px">انضممت كـ</p>
      <div class="role-badge" id="welcome-role"></div>
      <div class="sep"></div>
      <p class="sub">مرحباً بك <strong id="welcome-name"></strong>،<br>المنصة قيد البناء وستُطلق قريباً.</p>
      <button class="btn-primary" onclick="window.location.href='/'">العودة للرئيسية</button>
      <button class="btn-link" onclick="logout()">تسجيل الخروج</button>
    </div>
  </div>

</body>
</html>
